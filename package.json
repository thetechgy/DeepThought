{
  "name": "deepthought-theme",
  "version": "0.0.0",
  "private": true,
  "description": "Accessibility, security, and performance validation for the DeepThought Zola theme",
  "scripts": {
    "clean:highlighting": "node tests/clean-generated-highlighting.js",
    "prebuild": "npm run clean:highlighting",
    "prebuild:test": "npm run clean:highlighting",
    "pretest:config": "npm run clean:highlighting",
    "build": "zola build",
    "build:test": "zola build --base-url http://127.0.0.1:4173",
    "test": "npm run test:config && playwright test",
    "test:config": "node --test tests/configuration-check.js",
    "test:a11y": "playwright test tests/accessibility.spec.js",
    "audit": "lhci autorun",
    "validate": "npm run build:test && npm run test && npm run audit"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1"
  },
  "overrides": {
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  }
}
